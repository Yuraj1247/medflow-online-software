{
  "name": "medflow-hms",
  "version": "1.0.0",
  "description": "MedFlow Hospital Management System",
  "author": "MedFlow",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
